# ============================================================
# Peko Beauty - Apache .htaccess for SiteGround Static Deployment
# Next.js static export (output: 'export' + trailingSlash: true)
# ============================================================

Options -Indexes

# ============================================================
# Rewrite Engine
# ============================================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ──────────────────────────────────────────────────────
    # 1. Force HTTPS (SiteGround 支援)
    # ──────────────────────────────────────────────────────
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # ──────────────────────────────────────────────────────
    # 2. 靜態資源直接提供，不做任何 rewrite
    #    (_next/, images/, *.ico, *.txt, *.xml 等)
    # ──────────────────────────────────────────────────────
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ──────────────────────────────────────────────────────
    # 3. 處理帶 .html 副檔名的直接請求
    #    /about.html → /about/ (301 redirect)
    # ──────────────────────────────────────────────────────
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
    RewriteRule ^ /%1/ [R=301,L]

    # ──────────────────────────────────────────────────────
    # 4. 核心 SPA 路由：將所有未匹配的請求指向對應 index.html
    #    因為 trailingSlash: true，Next.js 產生的結構是：
    #    /about/ → /about/index.html
    #    /treatments/sylfirm-x/ → /treatments/sylfirm-x/index.html
    # ──────────────────────────────────────────────────────
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ /$1/index.html [L]

</IfModule>

# ============================================================
# 自訂錯誤頁面
# ============================================================
ErrorDocument 404 /404/index.html
ErrorDocument 403 /404/index.html

# ============================================================
# MIME Types for Next.js static assets
# ============================================================
<IfModule mod_mime.c>
    AddType application/javascript .js .mjs
    AddType text/css .css
    AddType image/svg+xml .svg
    AddType application/json .json
    AddType font/woff2 .woff2
    AddType font/woff .woff
    # 確保 .txt 文件以 UTF-8 編碼提供，防止中文亂碼
    AddType "text/plain; charset=utf-8" .txt
    AddCharset utf-8 .txt .xml .json
</IfModule>

# ============================================================
# Gzip 壓縮 (SiteGround 通常已啟用，此為 fallback)
# ============================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain image/svg+xml
</IfModule>

# ============================================================
# 瀏覽器快取設定
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Next.js 帶 hash 的靜態資源 (_next/static/) — 長期快取
    <FilesMatch "\.(js|css|woff2|woff|ttf|otf|eot)$">
        ExpiresDefault "access plus 1 year"
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # 圖片
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|ico|svg)$">
        ExpiresDefault "access plus 3 months"
        Header set Cache-Control "public, max-age=7776000"
    </FilesMatch>

    # HTML — 不快取，確保更新即時生效
    <FilesMatch "\.html$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# ============================================================
# 安全性 Headers
# ============================================================
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
